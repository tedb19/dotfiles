# Theme
theme = Catppuccin Mocha

# Font
font-family = JetBrainsMono Nerd Font Mono
font-style = Medium
font-size = 14
adjust-cell-height = 50%

# Cursor
cursor-style = bar
cursor-style-blink = true

# Window
macos-titlebar-style = hidden
window-padding-x = 30
window-padding-y = 30
macos-window-shadow = true
confirm-close-surface = false
window-save-state = always

# Use standard terminfo for SSH compatibility
term = xterm-256color

# Scrollback
scrollback-limit = 5000

# Keybindings — line editing
keybind = super+left=text:\x01
keybind = super+right=text:\x05
keybind = alt+left=text:\x1bb
keybind = alt+right=text:\x1bf
keybind = shift+super+backspace=text:\x15
keybind = shift+alt+backspace=text:\x17

# Keybindings — pane splitting
keybind = super+shift+backslash=new_split:right
keybind = super+shift+minus=new_split:down

# Keybindings — pane navigation
keybind = super+shift+left=goto_split:left
keybind = super+shift+right=goto_split:right
keybind = super+shift+up=goto_split:top
keybind = super+shift+down=goto_split:bottom

# Keybindings — pane resize
keybind = super+shift+h=resize_split:left,10
keybind = super+shift+l=resize_split:right,10
keybind = super+shift+k=resize_split:up,10
keybind = super+shift+j=resize_split:down,10

# Keybindings — pane management
keybind = super+shift+z=toggle_split_zoom
keybind = super+shift+w=close_surface
